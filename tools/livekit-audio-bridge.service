[Unit]
Description=Smart Helmet LiveKit Bidirectional Audio Bridge
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=trc
WorkingDirectory=/home/trc/Desktop/Projects/Streaming-Rpi/hm_releases
EnvironmentFile=/home/trc/Desktop/Projects/Streaming-Rpi/hm_releases/.env
ExecStart=/home/trc/Desktop/Projects/Streaming-Rpi/hm_releases/venv/bin/python tools/livekit_audio_bridge.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
